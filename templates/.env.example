# =============================================================================
# Brain Vault Environment Variables
# Copy this file to your vault root as `.env` and fill in your actual values.
# This file is gitignored and should never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Google OAuth (Gmail, Calendar, Drive, Docs)
# Recommended: generate OAuth credentials with `gws` CLI.
# Fallback: use https://console.cloud.google.com
# Enable: Gmail API, Calendar API, Drive API, Docs API
# Scopes needed: gmail.modify, calendar, drive
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# -----------------------------------------------------------------------------
# Fathom (meeting transcripts and summaries)
# Get your API key from https://app.fathom.video/settings/api
# -----------------------------------------------------------------------------
FATHOM_API_KEY=your_fathom_api_key

# Optional: webhook secret for real-time transcript notifications
FATHOM_WEBHOOK_SECRET=your_fathom_webhook_secret

# -----------------------------------------------------------------------------
# Slack (one OAuth token per workspace)
# Create a Slack app at https://api.slack.com/apps
# Scopes: channels:history, channels:read, chat:write, im:history, im:read,
#          mpim:history, mpim:read, users:read
# Install to each workspace and copy the OAuth token
# -----------------------------------------------------------------------------
SLACK_TOKEN_WORKSPACE_A=xoxp-your-workspace-a-token
SLACK_TOKEN_WORKSPACE_B=xoxp-your-workspace-b-token
# Add more workspaces as needed:
# SLACK_TOKEN_WORKSPACE_C=xoxp-...

# Slack app credentials (for OAuth flow if building custom app)
SLACK_APP_ID=your_slack_app_id
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Your Slack user ID (for DM notifications from automation)
SLACK_USER_ID_OWNER=U0XXXXXXXXX

# -----------------------------------------------------------------------------
# Time Tracking (optional -- only if you use a time tracker with an API)
# Example: Rize (GraphQL) -- get your API key from https://rize.io/settings
# Adapt the variable name and endpoint for your specific time tracker.
# -----------------------------------------------------------------------------
# RIZE_API_KEY=your_rize_api_key

# -----------------------------------------------------------------------------
# Task Manager (if using REST API directly instead of MCP)
# Example: ClickUp -- get your API key from https://app.clickup.com/settings/apps
# Adapt the variable name for your specific task manager.
# -----------------------------------------------------------------------------
# CLICKUP_API_KEY=your_clickup_api_key
